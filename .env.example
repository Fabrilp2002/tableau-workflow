# ─────────────────────────────────────────
# Tableau Workflow Assistant — Config
# Renombrá este archivo a .env
# ─────────────────────────────────────────

# Tu site de Tableau Cloud.
# TABLEAU_SITE_NAME es el "content URL" del site, que ves en la URL del browser
# después de loguearte: https://.../#/site/<ESTE-VALOR>/projects
# NO es el display name visible en la UI — es el slug de la URL.
TABLEAU_SERVER_URL=https://prod-useast-a.online.tableau.com
TABLEAU_SITE_NAME=your-site-slug

# Personal Access Token (Settings > My Account > Personal Access Tokens).
# IMPORTANTE: NUNCA pegues el secret real acá. Este archivo es el template
# que se commitea/comparte. Pegalo solo en tu .env local (que está en .gitignore).
TABLEAU_PAT_NAME=mcp-workflow
TABLEAU_PAT_VALUE=your-pat-secret-here

# Local folder with your .twb/.twbx files
# Examples:
#   Windows: C:/Users/<you>/Documents/Tableau
#   Mac:     /Users/<you>/Documents/Tableau
TABLEAU_LOCAL_FOLDER=

# Path donde guardar el catálogo indexado (JSON)
# Default: ~/.tableau-workflow/catalog.json
TABLEAU_CATALOG_PATH=
